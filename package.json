{
  "name": "fastify-react-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "node tools/dev/start-dev.mjs",
    "dev:infra": "node tools/dev/start-dev.mjs --infra-only",
    "dev:api": "pnpm run db:migrate && pnpm --filter @agent/api dev",
    "dev:web": "pnpm --filter @agent/web dev",
    "dev:worker": "pnpm run db:migrate && pnpm --filter @agent/api dev:worker",
    "db:migrate": "pnpm --filter @agent/api db:migrate",
    "db:rollback": "pnpm --filter @agent/api db:rollback",
    "db:migration:create": "pnpm --filter @agent/api db:migration:create",
    "build": "pnpm --filter @agent/api build && pnpm --filter @agent/web build",
    "test": "pnpm run test:tools && pnpm --filter @agent/api test && pnpm --filter @agent/web test",
    "test:tools": "node --test tools/*/*.test.mjs",
    "typecheck": "pnpm --filter @agent/contracts typecheck && pnpm --filter @agent/api typecheck && pnpm --filter @agent/web typecheck",
    "confluence:ingest": "node tools/confluence-import/ingest-confluence.mjs",
    "mock:llm": "node tools/loadtest/mock-llm-server.mjs",
    "loadtest": "k6 run tools/loadtest/k6-loadtest.js",
    "loadtest:ingress": "MODE=ingress k6 run tools/loadtest/k6-loadtest.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^9.2.3"
  }
}
