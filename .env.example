PORT=4001
HOST=0.0.0.0
CORS_ORIGINS=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=embeddinggemma

REDIS_URL=redis://localhost:6379
AGENT_WORKER_CONCURRENCY=2
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent
AGENT_UPLOAD_DIR=./data/uploads
# 开发调试上传 loading 用；生产保持 0。
AGENT_UPLOAD_RESPONSE_DELAY_MS=0

# GitHub OAuth 登录。client secret 不要提交到仓库，只放本地或部署环境变量。
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:4000/auth/github/callback
VITE_GITHUB_OAUTH_CLIENT_ID=
VITE_GITHUB_OAUTH_REDIRECT_URI=http://localhost:4000/auth/github/callback

# JWT 无状态授权。本地可用任意长随机字符串，生产请重新生成。
JWT_ACCESS_SECRET=change-me-access-token-secret
JWT_REFRESH_SECRET=change-me-refresh-token-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=1296000

# S3 兼容对象存储配置（图片上传用）
# 开发：连本地 MinIO（docker-compose 自带）
# 生产：把 endpoint/accessKey/secretKey 换成 Cloudflare R2 或 AWS S3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=agent-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# 留空则自动用 S3_ENDPOINT 作为图片访问 base URL
S3_PUBLIC_BASE_URL=

TAVILY_API_KEY=
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=
AGENT_ALLOWED_TOOLS=

CONFLUENCE_BASE_URL=https://doc.huanleguang.com
CONFLUENCE_USERNAME=
CONFLUENCE_PASSWORD=
CONFLUENCE_SEED_PAGE_ID=52773412

VITE_API_BASE_URL=

# OpenTelemetry 配置
# 留空则禁用可观测性；指向 SigNoz/Jaeger/阿里云 SLS 的 OTLP HTTP 端点
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
GRAFANA_PORT=3001
